generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Invoice {

  id            String        @id
  invoiceNumber String        @unique
  amount        Decimal
  currency      String        @default("INR")
  description   String
  fileUrl       String?

  status        InvoiceStatus @default(DRAFT)

  vendorId      String
  submittedById String

  deptApprovedById    String?
  financeApprovedById String?

  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paidAt DateTime?

  paymentNotes     String?
  paymentReference String?

  /* =========================
     RELATIONS
  ========================= */

  vendor            Vendor @relation(fields: [vendorId], references: [id])

  submittedBy       User  @relation("Invoice_submittedByIdToUser", fields: [submittedById], references: [id])

  deptApprovedBy    User? @relation("Invoice_deptApprovedByIdToUser", fields: [deptApprovedById], references: [id])

  financeApprovedBy User? @relation("Invoice_financeApprovedByIdToUser", fields: [financeApprovedById], references: [id])

  activities        InvoiceActivity[]

  /* =========================
     INDEXES (PERFORMANCE)
  ========================= */

  @@index([createdAt])
  @@index([status])
  @@index([submittedById])
  @@index([vendorId])

}

model InvoiceActivity {

  id        String   @id
  invoiceId String
  userId    String

  action    String
  metadata  String?

  createdAt DateTime @default(now())

  /* RELATIONS */

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

}

model User {

  id        String   @id
  email     String   @unique
  role      Role
  supabaseId String? @unique

  createdAt DateTime @default(now())

  /* RELATIONS */

  submittedInvoices Invoice[] @relation("Invoice_submittedByIdToUser")

  deptApprovedInvoices Invoice[] @relation("Invoice_deptApprovedByIdToUser")

  financeApprovedInvoices Invoice[] @relation("Invoice_financeApprovedByIdToUser")

  activities InvoiceActivity[]

}

model Vendor {

  id        String   @id
  name      String
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())

  invoices Invoice[]

}

enum InvoiceStatus {
  DRAFT
  SUBMITTED
  DEPT_APPROVED
  FINANCE_APPROVED
  PAID
  REJECTED
}

enum Role {
  VENDOR
  DEPARTMENT
  FINANCE
  ACCOUNTS
  ADMIN
}
